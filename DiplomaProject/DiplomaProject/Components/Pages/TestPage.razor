@page "/test"
@using DiplomaProject.Services
@using DiplomaProject.Models
@inject TestService TestService
@inject TestGeneration TestGeneration
@rendermode InteractiveServer

<h3>TestPage</h3>

<div style="height: 20px;"></div>

<div class="d-flex gap-2 flex-wrap">
    @for (int i = 0; i < state.Tests.Count; i++)
    {
        var index = i;
        <button class="btn @GetQuestionButtonClass(index)"
                @onclick="() => ButtonShowParticular(index)">
            @(i + 1)
        </button>
    }
</div>

<div style="height: 20px;"></div>

@if (state.Tests != null && state.CurrentQuestion < state.Tests.Count)
{
    var tIndex = state.CurrentQuestion;

    <div>
        <h4>#@(tIndex + 1)</h4>
        <h4>@state.Tests[tIndex].TaskDescription</h4>

        @if (state.Tests[tIndex].CorrectAnswerIndexList.Count > 1)
        {
            <ul>
                @for (int i = 0; i < state.Tests[tIndex].TaskAnswers.Count; i++)
                {
                    var iIndex = i;

                   
                    <li style="@GetAnswerStyle(tIndex, iIndex)">

                        <input type="checkbox"
                               checked="@state.SelectedCheckbox[tIndex][iIndex]"
                               disabled="@state.ShowResult"
                               @onchange="e => state.SelectedCheckbox[tIndex][iIndex] = (bool)e.Value" />

                        @state.Tests[tIndex].TaskAnswers[iIndex]
                    </li>
                }
            </ul>
        }
        else
        {
            @for (int i = 0; i < state.Tests[tIndex].TaskAnswers.Count; i++)
            {
                var iIndex = i;

                
                <li style="@GetAnswerStyle(tIndex, iIndex)">

                    <input type="radio"
                           name="q"
                           checked="@(state.SelectedRadio[tIndex] == iIndex)"
                           disabled="@state.ShowResult"
                           @onchange="e => state.SelectedRadio[tIndex] = iIndex" />

                    @state.Tests[tIndex].TaskAnswers[iIndex]
                </li>
            }
        }
    </div>
}

@if (state.Tests != null && state.CurrentQuestion >= state.Tests.Count)
{
    <div>
        <button class="btn btn-primary" @onclick="ButtonCheck">
            Check your answers
        </button>
    </div>

    @if (state.ShowResult)
    {
        <h4>Result: @state.Score / @state.Tests.Count</h4>
    }
}

<div style="height: 20px;"></div>



<div style="position: fixed; bottom: 20px; left: 275px;">
    <button class="btn btn-primary" @onclick="ButtonBack">
        Previous question
    </button>
</div>

<div style="position: fixed; bottom: 20px; left: 475px;">
    <button class="btn btn-primary" @onclick="ButtonNext">
        Next question
    </button>
</div>


@code {
    TestState state;
    [Parameter]
    public string InstanceId { get; set; }
    protected override void OnInitialized()
    {
        state = new TestState();

        state.Tests = TestGeneration.GetSampleTests();

        state.SelectedCheckbox = state.Tests
            .Select(t => t.TaskAnswers.Select(a => false).ToList())
            .ToList();

        state.SelectedRadio = state.Tests
            .Select(t => -1)
            .ToList();
    }

    bool IsAnswered(int t)
    {
        if (state.Tests[t].CorrectAnswerIndexList.Count == 1)
            return state.SelectedRadio[t] != -1;

        return state.SelectedCheckbox[t].Any(x => x);
    }

    bool IsCorrect(int t)
    {
        if (state.Tests[t].CorrectAnswerIndexList.Count == 1)
            return state.SelectedRadio[t] == state.Tests[t].CorrectAnswerIndexList[0];

        for (int i = 0; i < state.Tests[t].TaskAnswers.Count; i++)
        {
            bool mustBeChecked = state.Tests[t].CorrectAnswerIndexList.Contains(i);

            if (state.SelectedCheckbox[t][i] != mustBeChecked)
                return false;
        }

        return true;
    }

   
    string GetQuestionButtonClass(int index)
    {
        if (state.ShowResult)
            return IsCorrect(index) ? "btn-success" : "btn-danger";

        if (state.CurrentQuestion == index)
            return "btn-primary";

        if (IsAnswered(index))
            return "btn-success";

        return "btn-outline-secondary";
    }

    
    string GetAnswerStyle(int tIndex, int iIndex)
    {
        if (!state.ShowResult)
            return "";

        if (state.Tests[tIndex].CorrectAnswerIndexList.Contains(iIndex))
            return "color: green;";

        if (state.Tests[tIndex].CorrectAnswerIndexList.Count == 1)
        {
            return state.SelectedRadio[tIndex] == iIndex ? "color: red;" : "";
        }

        return state.SelectedCheckbox[tIndex][iIndex] ? "color: red;" : "";
    }
    

    private void ButtonCheck()
    {
        state.Score = 0;

        for (int t = 0; t < state.Tests.Count; t++)
        {
            if (IsCorrect(t))
                state.Score++;
        }

        state.ShowResult = true;
    }


    private void ButtonNext()
    {
        if (state.CurrentQuestion < state.Tests.Count)
        {
            state.CurrentQuestion++;
        }
    }

    private void ButtonBack()
    {
        if (state.CurrentQuestion > 0)
        {
            state.CurrentQuestion--;
        }
    }

    private void ButtonShowParticular(int index)
    {
        state.CurrentQuestion = index;
    }
}